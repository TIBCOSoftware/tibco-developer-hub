{
  "name": "root",
  "version": "1.19.0",
  "private": true,
  "engines": {
    "node": "22 || 24"
  },
  "scripts": {
    "start": "backstage-cli repo start",
    "build:backend": "yarn workspace backend build",
    "build:all": "backstage-cli repo build --all",
    "build-image": "yarn workspace backend build-image",
    "tsc": "tsc",
    "tsc:full": "tsc --skipLibCheck false --incremental false",
    "clean": "backstage-cli repo clean",
    "test": "backstage-cli repo test",
    "test:all": "backstage-cli repo test --silent --coverage --testResultsProcessor jest-sonar-reporter --runInBand --testTimeout=30000",
    "test:e2e": "playwright test",
    "fix": "backstage-cli repo fix",
    "lint": "backstage-cli repo lint --since origin/main",
    "lint:all": "backstage-cli repo lint",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "new": "backstage-cli new"
  },
  "backstage": {
    "cli": {
      "new": {
        "globals": {
          "license": "UNLICENSED"
        }
      }
    }
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "plugins/*"
    ]
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.2",
    "@backstage/cli-defaults": "^0.1.2",
    "@backstage/e2e-test-utils": "^0.1.2",
    "@jest/environment-jsdom-abstract": "^30.0.0",
    "@playwright/test": "^1.32.3",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "jest-sonar-reporter": "^2.0.0",
    "jsdom": "^27.1.0",
    "node-gyp": "^10.0.0",
    "prettier": "^2.3.2",
    "typescript": "~5.8.0"
  },
  "resolutions": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@protobufjs/inquire": "1.1.0",
    "@tootallnate/once": "^3.0.1",
    "@octokit/request-error": "^7.1.0",
    "@octokit/request": "^10.0.8",
    "undici": "^8.2.0",
    "tar": "^7.5.14",
    "tough-cookie": "^6.0.1",
    "file-type": "^22.0.1",
    "@octokit/plugin-paginate-rest": "^14.0.0",
    "jsonpath-plus": "^10.3.0",
    "form-data": "^4.0.5",
    "qs": "^6.15.1",
    "underscore": "^1.13.8",
    "uuid": "^11.1.1",
    "@material-table/core@npm:^3.1.0": "patch:@material-table/core@npm%3A3.2.5#~/.yarn/patches/@material-table-core-npm-3.2.5-5a76f950c0.patch",
    "@backstage/frontend-test-utils@npm:^0.4.5": "patch:@backstage/frontend-test-utils@npm%3A0.4.5#~/.yarn/patches/@backstage-frontend-test-utils-npm-0.4.5-a8928a36b8.patch"
  },
  "prettier": "@backstage/cli/config/prettier",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "jest": {
    "testTimeout": 30000
  },
  "packageManager": "yarn@4.4.1"
}
