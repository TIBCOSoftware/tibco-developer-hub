{
  "name": "root",
  "version": "1.18.0",
  "private": true,
  "engines": {
    "node": "22 || 24"
  },
  "scripts": {
    "start": "NODE_OPTIONS=--no-node-snapshot backstage-cli repo start",
    "build:backend": "yarn workspace backend build",
    "build:all": "backstage-cli repo build --all",
    "build-image": "yarn workspace backend build-image",
    "tsc": "tsc",
    "tsc:full": "tsc --skipLibCheck false --incremental false",
    "clean": "backstage-cli repo clean",
    "test": "backstage-cli repo test",
    "test:all": "backstage-cli repo test --silent --coverage --testResultsProcessor jest-sonar-reporter --runInBand --testTimeout=30000",
    "test:e2e": "playwright test",
    "fix": "backstage-cli repo fix",
    "lint": "backstage-cli repo lint --since origin/main",
    "lint:all": "backstage-cli repo lint",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "new": "backstage-cli new"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "plugins/*"
    ]
  },
  "devDependencies": {
    "@backstage/cli": "^0.33.1",
    "@backstage/e2e-test-utils": "^0.1.1",
    "@playwright/test": "^1.32.3",
    "@spotify/prettier-config": "^12.0.0",
    "@types/lodash": "^4.17.16",
    "jest-sonar-reporter": "^2.0.0",
    "node-gyp": "^10.0.0",
    "prettier": "^2.3.2",
    "typescript": "~5.8.0"
  },
  "resolutions": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@testing-library/react": "^16.0.0",
    "@testing-library/dom": "^10.4.0",
    "isolated-vm": "^6.0.2",
    "@kubernetes/client-node": "^1.0.0-rc7",
    "jsonpath-plus": "^10.3.0",
    "@octokit/request-error": "^5.1.1",
    "@octokit/request": "^8.4.1",
    "@octokit/plugin-paginate-rest": "^9.2.2",
    "tar-fs": "^2.1.4",
    "tar": "^7.5.11",
    "axios": "^1.15.2",
    "fast-redact": "^3.5.0",
    "undici": "^7.24.5",
    "@swc/core": "1.13.5",
    "fast-xml-parser": "^5.7.0",
    "@backstage/plugin-techdocs-node": "^1.14.1",
    "@isaacs/brace-expansion": "^5.0.1",
    "@tootallnate/once": "^3.0.1",
    "underscore": "^1.13.8",
    "file-type": "^21.3.1",
    "flatted": "^3.4.0",
    "yauzl": "^3.2.1",
    "protobufjs": "patch:protobufjs@npm%3A8.2.0#~/.yarn/patches/protobufjs-npm-8.2.0-4e3436a238.patch",
    "basic-ftp": "^5.3.1",
    "follow-redirects": "^1.16.0",
    "uuid": "^14.0.0",
    "@xmldom/xmldom": "^0.8.13",
    "ip-address": "^10.1.1",
    "vm2": "^3.11.2",
    "fast-uri": "^3.1.2",
    "fast-xml-builder": "^1.1.7",
    "@protobufjs/utf8": "1.1.1",
    "@material-table/core@npm:^3.1.0": "patch:@material-table/core@npm%3A3.2.5#~/.yarn/patches/@material-table-core-npm-3.2.5-5a76f950c0.patch"
  },
  "prettier": "@spotify/prettier-config",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "jest": {
    "testTimeout": 10000
  },
  "packageManager": "yarn@4.4.1"
}
